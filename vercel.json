{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/src/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "client/$1"
    }
  ],
  "functions": {
    "server/src/index.ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 60
    }
  },
  "installCommand": "npm install"
}