{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/chat/sessions/:id/messages",
      "destination": "/api/chat/sessions/[id]/messages"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "installCommand": "npm install",
  "outputDirectory": "client/dist"
}